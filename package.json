{
  "name": "immortals-overlay",
  "version": "1.0.12",
  "description": "33 Immortals — overlay de la carte interactive (toujours au-dessus du jeu)",
  "author": "33 Immortals FR",
  "license": "BSD-3-Clause",
  "homepage": "https://33immortals.fr",
  "repository": { "type": "git", "url": "https://github.com/StrangeLex/33immortals-overlay.git" },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "fr.33immortals.overlay",
    "productName": "33 Immortals Overlay",
    "icon": "build/icon.ico",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "build/icon.ico"],
    "publish": [{ "provider": "github", "owner": "StrangeLex", "repo": "33immortals-overlay" }],
    "win": { "target": ["nsis"], "artifactName": "33ImmortalsOverlay-Setup-${version}.${ext}" },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true,
      "differentialPackage": true,
      "artifactName": "33ImmortalsOverlay-Setup-${version}.${ext}"
    }
  }
}
